	email = 3741250+contento@users.noreply.github.com
	name = Gonzalo Contento

[core]
    autocrlf = input   # Useful on cross-platform systems (LF for macOS/Linux, CRLF on Windows)
    hooksPath = .githooks

[color]
    ui = true   # Enable colored output

[credential]
    helper = cache  # Cache credentials for a while
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential