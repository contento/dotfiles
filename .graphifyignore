# graphify ignore -- keep the graph focused on first-party config and scripts.
# NOTE: graphify uses .graphifyignore INSTEAD of the root .gitignore, so the
# build-artifact exclusions below must be repeated here (they are not inherited).

# ==============================================================================
# Third-party plugins & dependencies (keep canonical lockfiles like lazy-lock.json)
# ==============================================================================
**/tmux/plugins/
zsh/.config/zsh/zsh-autosuggestions/
zsh/.config/zsh/zsh-completions/
zsh/.config/zsh/zsh-highlighting/
node_modules/
vendor/

# ==============================================================================
# Runtime & cache files (machine-specific state)
# ==============================================================================
zsh/.config/zsh/.zsh_history
zsh/.config/zsh/.zcompdump
nvim/.config/nvim/lazyvim.json
zed/.config/zed/prompts/prompts-library-db.0.mdb

# ==============================================================================
# Backup & temporary files
# ==============================================================================
**/backup/
*.bak
*.tmp
*.swp
*.swo
*~

# ==============================================================================
# OS & editor cruft
# ==============================================================================
**/.DS_Store
Thumbs.db
.vscode/
.idea/

# ==============================================================================
# Logs
# ==============================================================================
*.log

# ==============================================================================
# graphify cache (regenerable, machine-specific metadata)
# ==============================================================================
graphify-out/cache/
graphify-out/.graphify_*
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/memory/
