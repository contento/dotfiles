# ==============================================================================
# Claude Code local settings (worktrees, session data)
# ==============================================================================
.claude/settings.local.json

# ==============================================================================
# OS & editor cruft
# ==============================================================================
**/.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ==============================================================================
# Tool runtime & cache (third-party plugins, shell history, databases)
# ==============================================================================
# NOTE: lazy-lock.json intentionally NOT ignored — we track plugin lockfiles

# tmux plugin manager
**/tmux/plugins/

# zsh third-party plugins & history
zsh/.config/zsh/zsh-autosuggestions/
zsh/.config/zsh/zsh-completions/
zsh/.config/zsh/zsh-highlighting/
zsh/.config/zsh/.zsh_history
zsh/.config/zsh/.zcompdump

# nvim runtime state
nvim/.config/nvim/lazyvim.json

# zed editor cache / databases
zed/.config/zed/prompts/prompts-library-db.0.mdb

# fastfetch backup config
fastfetch/.config/fastfetch/config.jsonc.bak

# ==============================================================================
# Backup & scratch files
# ==============================================================================
**/backup/
*.bak

# ==============================================================================
# Logs
# ==============================================================================
*.log

# ==============================================================================
# graphify knowledge graph (regenerated from source via `graphify update .`)
# ==============================================================================
graphify-out/
